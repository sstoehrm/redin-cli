;; ---------------------------------------------------------------------------
;; Main
;; ---------------------------------------------------------------------------

(let [args *command-line-args*
      cmd (first args)]
  (case cmd
    "new-fnl"           (cmd-new-fnl (second args))
    "new-lua"           (cmd-new-lua (second args))
    "upgrade-to-native" (cmd-upgrade-to-native)
    "update"            (cmd-update (second args))
    "latest"            (cmd-latest)
    "help"              (cmd-help)
    (do
      (cmd-help)
      (when (and cmd (not= cmd "--help") (not= cmd "-h"))
        (println)
        (println (str "Unknown command: " cmd))
        (System/exit 1)))))
