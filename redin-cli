;; ---------------------------------------------------------------------------
;; Templates: Native (RFC sstoehrm/redin#79)
;; ---------------------------------------------------------------------------
;; The user owns app.odin at the project root and imports redin from the
;; framework directory `.redin/src/redin/`. Custom canvas providers, Lua
;; cfuncs, and per-frame hooks are registered before redin.run takes over
;; the loop. Nothing in .redin/ is hand-edited — `redin-cli update`
;; freely overwrites it.

(def app-odin-fnl
  "package main

import \"core:os\"
import redin \"./.redin/src/redin\"

main :: proc() {
\tcfg: redin.Config
\tcfg.app = \"main.fnl\"
\tfor arg in os.args[1:] {
\t\tswitch arg {
\t\tcase \"--dev\":     cfg.dev = true
\t\tcase \"--profile\": cfg.profile = true
\t\tcase:             cfg.app = arg
\t\t}
\t}

\t// Register custom canvas providers / Lua cfuncs / hooks before run.
\t//
\t// import \"./.redin/src/redin/canvas\"
\t// import \"./.redin/src/redin/bridge\"
\t//
\t// canvas.register(\"my-provider\", my_provider)
\t// bridge.register_cfunc(\"my_signal\", my_cfunc)
\t// redin.on_frame(my_per_frame_tick)
\t//
\t// redin.set_window(1920, 1080, \"my game\", {.WINDOW_RESIZABLE})

\tredin.run(cfg)
}
")

(def app-odin-lua
  "package main

import \"core:os\"
import redin \"./.redin/src/redin\"

main :: proc() {
\tcfg: redin.Config
\tcfg.app = \"main.lua\"
\tfor arg in os.args[1:] {
\t\tswitch arg {
\t\tcase \"--dev\":     cfg.dev = true
\t\tcase \"--profile\": cfg.profile = true
\t\tcase:             cfg.app = arg
\t\t}
\t}

\tredin.run(cfg)
}
")

(def build-sh-native
  "#!/usr/bin/env bash
SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"
mkdir -p \"$SCRIPT_DIR/build\"
odin build \"$SCRIPT_DIR\" \\
  -collection:lib=\"$SCRIPT_DIR/.redin/lib\" \\
  -collection:luajit=\"$SCRIPT_DIR/.redin/vendor/luajit\" \\
  -out:\"$SCRIPT_DIR/build/redin\"
")

(def legacy-native-message
  "ERROR: This project uses the old native layout (native/ directory).

The native build now lives at the project root (app.odin) and imports
redin as a package from .redin/src/redin/. Migrate by:

  1. Save any custom code from native/providers.odin and edits to
     native/main.odin (window size, registered providers, cfuncs).
  2. rm -rf native/
  3. Re-run: redin-cli new-fnl --native .
  4. Open the freshly scaffolded app.odin and re-apply your customizations.

Your main.fnl / main.lua and other project files are untouched.
")

