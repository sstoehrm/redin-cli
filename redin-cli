SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"
if [ -f \"$SCRIPT_DIR/build/redin\" ]; then
  exec \"$SCRIPT_DIR/build/redin\" \"$@\"
else
  exec \"$SCRIPT_DIR/.redin/redin\" \"$@\"
fi
")

