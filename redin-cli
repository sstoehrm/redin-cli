(def providers-odin
  "package host

import \"canvas\"
import rl \"vendor:raylib\"

// Example: register a native Odin canvas provider.
// Reference it from Fennel/Lua with [:canvas {:provider :my-provider ...}]

my_provider := canvas.Canvas_Provider{
\tupdate = proc(rect: rl.Rectangle) {
\t\trl.DrawRectangleRec(rect, rl.Color{40, 40, 60, 255})
\t},
}

init_providers :: proc() {
\tcanvas.register(\"my-provider\", my_provider)
}
")

(def build-sh
  "#!/usr/bin/env bash
SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"
PROJECT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"
mkdir -p \"$PROJECT_DIR/build\"
odin build \"$SCRIPT_DIR\" -out:\"$PROJECT_DIR/build/redin\"
")

