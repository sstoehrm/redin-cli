#!/usr/bin/env bb

(require '[babashka.http-client :as http]
         '[cheshire.core :as json]
         '[clojure.java.io :as io]
         '[clojure.string :as str])

(def github-repo "sstoehrm/redin")
(def github-api (str "https://api.github.com/repos/" github-repo))

;; ---------------------------------------------------------------------------
;; GitHub API
;; ---------------------------------------------------------------------------

(defn fetch-latest-version []
  (let [resp (http/get (str github-api "/releases/latest")
                       {:headers {"Accept" "application/vnd.github.v3+json"}})
        data (json/decode (:body resp) true)]
    (:tag_name data)))

(defn fetch-release-info [version]
  (let [resp (http/get (str github-api "/releases/tags/" version)
                       {:headers {"Accept" "application/vnd.github.v3+json"}})
        data (json/decode (:body resp) true)]
    data))

(defn find-tarball-url [release]
  (let [assets (:assets release)]
    (->> assets
         (filter #(str/ends-with? (:name %) "-linux-amd64.tar.gz"))
         first
         :browser_download_url)))

(defn find-source-tarball-url [release]
  (:tarball_url release))

(defn download-file [url dest]
  (println (str "  Downloading " url))
  (let [resp (http/get url {:as :stream})]
    (io/copy (:body resp) (io/file dest))))

;; ---------------------------------------------------------------------------
;; Install release into .redin/
;; ---------------------------------------------------------------------------

(defn install-release [dir version]
  (let [redin-dir (io/file dir ".redin")
        tarball (io/file dir ".redin-download.tar.gz")]
    ;; Fetch release info
    (print (str "Fetching release " version "... "))
    (flush)
    (let [release (fetch-release-info version)
          url (find-tarball-url release)]
      (when-not url
        (println "FAILED")
        (println (str "No linux-amd64 tarball found for " version))
        (System/exit 1))
      (println "OK"))

    ;; Download
    (let [release (fetch-release-info version)
          url (find-tarball-url release)]
      (download-file url (.getPath tarball)))

    ;; Remove old .redin/ contents (keep directory)
    (when (.exists redin-dir)
      (doseq [f (reverse (file-seq redin-dir))]
        (when (not= f redin-dir)
          (.delete f))))
    (.mkdirs redin-dir)

    ;; Extract
    (println "  Extracting...")
    (let [exit (-> (ProcessBuilder. ["tar" "xzf" (.getAbsolutePath tarball) "-C" (.getAbsolutePath redin-dir)])
                   (.directory (io/file dir))
                   .start
                   .waitFor)]
      (when (not= exit 0)
        (println "  ERROR: tar extraction failed")
        (System/exit 1)))

    ;; Write version file
    (spit (io/file redin-dir "version") (str version "\n"))

    ;; Make binary executable
    (let [bin (io/file redin-dir "redin")]
      (when (.exists bin)
        (.setExecutable bin true)))

    ;; Cleanup tarball
    (.delete tarball)

    (println (str "  Installed redin " version " into .redin/"))))

