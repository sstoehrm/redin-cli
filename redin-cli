(def gitignore-content ".redin/\n.redin-port\n")

;; ---------------------------------------------------------------------------
;; Commands
;; ---------------------------------------------------------------------------

(defn copy-tree [src dst]
  (doseq [f (file-seq src)]
    (let [rel (.relativize (.toPath src) (.toPath f))
          target (io/file dst (.toString rel))]
      (if (.isDirectory f)
        (.mkdirs target)
        (do (.mkdirs (.getParentFile target))
            (io/copy f target))))))

(defn refresh-claude-skills [dir]
  ;; Mirror .redin/skills/ into .claude/skills/ (where Claude Code actually
  ;; looks). Framework skill dirs are wiped before copy so renames or
  ;; removals in a new release don't leave orphan files behind; sibling
  ;; user-authored skills in .claude/skills/ are untouched.
  (let [skills-src (io/file dir ".redin/skills")
        skills-dst (io/file dir ".claude/skills")]
    (when (.exists skills-src)
      (doseq [skill-dir (.listFiles skills-src)
              :when (.isDirectory skill-dir)]
        (let [target (io/file skills-dst (.getName skill-dir))]
          (when (.exists target)
            (doseq [f (reverse (file-seq target))]
              (.delete f)))))
      (copy-tree skills-src skills-dst))))

(defn scaffold-common [dir]
  ;; redinw
  (let [wrapper (io/file dir "redinw")]
    (spit wrapper redinw-script)
    (.setExecutable wrapper true))
  ;; .gitignore
  (let [gi (io/file dir ".gitignore")]
    (when-not (.exists gi)
      (spit gi gitignore-content)))
  (refresh-claude-skills dir))

(defn detect-legacy-native [dir]
  ;; If the project has the pre-RFC-79 native/ layout, refuse to scaffold
  ;; over it. Print migration instructions and exit.
  (when (.exists (io/file dir "native"))
    (println legacy-native-message)
    (System/exit 1)))

(defn fetch-source [dir version]
  ;; Download the source tarball for `version` and copy src/ + vendor/
  ;; into <dir>/.redin/. Idempotent: replaces any existing src/ and
  ;; vendor/ contents under .redin/. lib/ is not in the source tarball
  ;; (it's a submodule) — install-release places it under .redin/lib/.
  (println (str "Fetching redin source (" version ")..."))
  (let [release (fetch-release-info version)
        source-url (find-source-tarball-url release)
        tarball (io/file dir ".redin-source.tar.gz")]
    (when-not source-url
      (println "ERROR: No source tarball found for this release.")
      (System/exit 1))
    (download-file source-url (.getPath tarball))

    (println "  Extracting source...")
    (let [tmp-dir (io/file dir ".redin-source-tmp")]
      (.mkdirs tmp-dir)
      (let [exit (-> (ProcessBuilder. ["tar" "xzf" (.getAbsolutePath tarball)
                                        "-C" (.getAbsolutePath tmp-dir)
                                        "--strip-components=1"])
                     .start
                     .waitFor)]
        (when (not= exit 0)
          (println "  ERROR: source extraction failed")
          (System/exit 1)))

      ;; Replace src/ and vendor/ inside .redin/ with the freshly
      ;; extracted versions.
      (doseq [subdir ["src" "vendor"]]
        (let [src (io/file tmp-dir subdir)
              dst (io/file dir ".redin" subdir)]
          (when (.exists src)
            (when (.exists dst)
              (doseq [f (reverse (file-seq dst))]
                (when (not= f dst) (.delete f))))
            (doseq [f (file-seq src)]
              (let [rel (.relativize (.toPath src) (.toPath f))
                    target (io/file dst (.toString rel))]
                (if (.isDirectory f)
                  (.mkdirs target)
                  (do (.mkdirs (.getParentFile target))
                      (io/copy f target))))))))

      ;; Cleanup
      (doseq [f (reverse (file-seq tmp-dir))]
        (.delete f))
      (.delete tarball))))

(defn scaffold-native [dir kind]
  ;; kind: :fennel or :lua. Drops app.odin (with the right starter) and
  ;; build.sh at project root, switches redinw to the native variant
  ;; (prefer build/redin if present, else .redin/redin), and adds build/
  ;; to .gitignore.
  (let [app-content (case kind :fennel app-odin-fnl :lua app-odin-lua)
        app-file    (io/file dir "app.odin")
        build-file  (io/file dir "build.sh")
        redinw-file (io/file dir "redinw")
        gi-file     (io/file dir ".gitignore")]

    (when-not (.exists app-file)
      (spit app-file app-content))

    (spit build-file build-sh-native)
    (.setExecutable build-file true)

    (spit redinw-file redinw-native-script)
    (.setExecutable redinw-file true)

    (when (.exists gi-file)
      (let [content (slurp gi-file)]
        (when-not (str/includes? content "build/")
          (spit gi-file (str content "build/\n")))))))

(defn parse-new-args [args usage]
  ;; Pull --native flag out of `args`; the remainder is positional.
  ;; Returns {:native? bool :name string-or-nil}.
  (let [native? (boolean (some #{"--native"} args))
        positional (remove #{"--native"} args)
        name (first positional)]
    (when (or (nil? name) (str/blank? name))
      (println usage)
      (System/exit 1))
    {:native? native? :name name}))

(defn cmd-new-fnl [args]
  (let [{:keys [native? name]}
        (parse-new-args args "Usage: redin-cli new-fnl [--native] <project-name>")
        dir (io/file name)]

    (if (.exists dir)
      (println (str "Installing redin into " name))
      (do
        (println (str "Creating Fennel redin project: " name))
        (.mkdirs dir)))

    (when native?
      (detect-legacy-native dir))

    (let [version (fetch-latest-version)]
      (println (str "Latest version: " version))
      (install-release (.getPath dir) version)

      (scaffold-common dir)

      ;; Starter files
      (let [main-file (io/file dir "main.fnl")]
        (when-not (.exists main-file)
          (spit main-file main-fnl)))
      (let [fls-file (io/file dir "flsproject.fnl")]
        (when-not (.exists fls-file)
          (spit fls-file flsproject-fnl)))

      (when native?
        (fetch-source dir version)
        (scaffold-native dir :fennel)))

    (println)
    (println "Done!")
    (if native?
      (do
        (println "  ./build.sh                    # build native binary")
        (println "  ./redinw --dev main.fnl       # runs build/redin if present"))
      (println "  ./redinw --dev main.fnl"))
    (println "  Docs:  .redin/docs/")
    (println "  Skill: .claude/skills/redin-dev/  (Claude Code)")
    (println)))

(defn cmd-new-lua [args]
  (let [{:keys [native? name]}
        (parse-new-args args "Usage: redin-cli new-lua [--native] <project-name>")
        dir (io/file name)]

    (if (.exists dir)
      (println (str "Installing redin into " name))
      (do
        (println (str "Creating Lua redin project: " name))
        (.mkdirs dir)))

    (when native?
      (detect-legacy-native dir))

    (let [version (fetch-latest-version)]
      (println (str "Latest version: " version))
      (install-release (.getPath dir) version)

      (scaffold-common dir)

      ;; Starter files
      (let [main-file (io/file dir "main.lua")]
        (when-not (.exists main-file)
          (spit main-file main-lua)))
      (let [luarc-file (io/file dir ".luarc.json")]
        (when-not (.exists luarc-file)
          (spit luarc-file luarc-json)))

      (when native?
        (fetch-source dir version)
        (scaffold-native dir :lua)))

    (println)
    (println "Done!")
    (if native?
      (do
        (println "  ./build.sh                    # build native binary")
        (println "  ./redinw --dev main.lua       # runs build/redin if present"))
      (println "  ./redinw --dev main.lua"))
    (println "  Docs:  .redin/docs/")
    (println "  Skill: .claude/skills/redin-dev/  (Claude Code)")
    (println)))

(defn cmd-upgrade-to-native []
  ;; Deprecated alias for `redin-cli new-fnl --native .` (or new-lua if
  ;; main.lua exists). Removed in a future release. See sstoehrm/redin#79.
  (println "DEPRECATED: `redin-cli upgrade-to-native` is deprecated.")
  (println "            Use `redin-cli new-fnl --native .` (or `new-lua --native .`)")
  (println "            See sstoehrm/redin#79 for the new layout.")
  (println)

  (when-not (.exists (io/file ".redin"))
    (println "Not a redin project (no .redin/ directory).")
    (println "Run this from your project root.")
    (System/exit 1))

  (let [lua? (.exists (io/file "main.lua"))]
    (if lua?
      (cmd-new-lua ["--native" "."])
      (cmd-new-fnl ["--native" "."]))))

(defn cmd-update [version-arg]
  (when-not (.exists (io/file ".redin"))
    (println "Not a redin project (no .redin/ directory).")
    (println "Run this from your project root.")
    (System/exit 1))

  (let [current (str/trim (slurp ".redin/version"))
        version (or version-arg (fetch-latest-version))]
    (if (= current version)
      (println (str "Already on " version))
      (do
        (println (str "Updating from " current " to " version))
        (install-release "." version)))
    ;; Always refresh .claude/skills/ — this is where Claude Code looks.
    ;; Projects scaffolded before the skill location was standardized
    ;; (see sstoehrm/redin#73) don't have it, and won't get it from
    ;; install-release alone, so self-heal on every update.
    (refresh-claude-skills (io/file "."))
    (println "Done!")))

(defn cmd-latest []
  (let [version (fetch-latest-version)]
    (println version)))

