(dataflow.init {:counter 0})
(global redin_get_state (. dataflow :_get-raw-db))

(reg-handler :event/inc
  (fn [db event] (update db :counter #(+ $1 1))))

(reg-sub :sub/counter
  (fn [db] (get db :counter)))

