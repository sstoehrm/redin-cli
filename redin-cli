(defn copy-tree [src dst]
  (doseq [f (file-seq src)]
    (let [rel (.relativize (.toPath src) (.toPath f))
          target (io/file dst (.toString rel))]
      (if (.isDirectory f)
        (.mkdirs target)
        (do (.mkdirs (.getParentFile target))
            (io/copy f target))))))

(defn scaffold-common [dir]
  ;; redinw
  (let [wrapper (io/file dir "redinw")]
    (spit wrapper redinw-script)
    (.setExecutable wrapper true))
  ;; .gitignore
  (let [gi (io/file dir ".gitignore")]
    (when-not (.exists gi)
      (spit gi gitignore-content)))
  ;; Copy skills from .redin/ into .claude/skills/
  (let [skills-src (io/file dir ".redin/skills")
        skills-dst (io/file dir ".claude/skills")]
    (when (.exists skills-src)
      (copy-tree skills-src skills-dst))))

(defn cmd-new-fnl [name]
  (when (or (nil? name) (str/blank? name))
    (println "Usage: redin-cli new-fnl <project-name>")
    (System/exit 1))

  (let [dir (io/file name)]
    (if (.exists dir)
      (println (str "Installing redin into " name))
      (do
        (println (str "Creating Fennel redin project: " name))
        (.mkdirs dir)))

    (let [version (fetch-latest-version)]
      (println (str "Latest version: " version))
      (install-release (.getPath dir) version))

    (scaffold-common dir)

    ;; Write starter files if they don't exist yet
    (let [main-file (io/file dir "main.fnl")]
      (when-not (.exists main-file)
        (spit main-file main-fnl)))
    (let [fls-file (io/file dir "flsproject.fnl")]
      (when-not (.exists fls-file)
        (spit fls-file flsproject-fnl)))

    (println)
    (println "Done!")
    (println "  ./redinw --dev main.fnl")
    (println "  Docs:  .redin/docs/")
    (println "  Skill: .claude/skills/redin-dev/  (Claude Code)")
    (println)))

(defn cmd-new-lua [name]
  (when (or (nil? name) (str/blank? name))
    (println "Usage: redin-cli new-lua <project-name>")
