    (println "  Skill: .claude/skills/redin-dev/  (Claude Code)")
    (println)))

(defn cmd-upgrade-to-native []
  (when-not (.exists (io/file ".redin"))
    (println "Not a redin project (no .redin/ directory).")
    (println "Run this from your project root.")
    (System/exit 1))

  (let [version (str/trim (slurp ".redin/version"))
        native-dir (io/file "native")]

    ;; Download source into .redin/
    (println (str "Fetching redin source (" version ")..."))
    (let [release (fetch-release-info version)
          source-url (find-source-tarball-url release)
          tarball (io/file ".redin-source.tar.gz")]
      (when-not source-url
        (println "ERROR: No source tarball found for this release.")
        (System/exit 1))
      (download-file source-url (.getPath tarball))

      ;; Extract source into temp dir, then copy src/ and vendor/
      (println "  Extracting source...")
      (let [tmp-dir (io/file ".redin-source-tmp")]
        (.mkdirs tmp-dir)
        (let [exit (-> (ProcessBuilder. ["tar" "xzf" (.getAbsolutePath tarball)
                                         "-C" (.getAbsolutePath tmp-dir)
                                         "--strip-components=1"])
                       .start
                       .waitFor)]
          (when (not= exit 0)
            (println "  ERROR: source extraction failed")
            (System/exit 1)))

        ;; Copy src/ and vendor/ into .redin/
        (doseq [subdir ["src" "vendor"]]
          (let [src (io/file tmp-dir subdir)
                dst (io/file ".redin" subdir)]
            (when (.exists src)
              ;; Remove old
              (when (.exists dst)
                (doseq [f (reverse (file-seq dst))]
                  (when (not= f dst) (.delete f))))
              ;; Copy
              (doseq [f (file-seq src)]
                (let [rel (.relativize (.toPath src) (.toPath f))
                      target (io/file dst (.toString rel))]
                  (if (.isDirectory f)
                    (.mkdirs target)
                    (do (.mkdirs (.getParentFile target))
                        (io/copy f target))))))))

        ;; Cleanup
        (doseq [f (reverse (file-seq tmp-dir))]
          (.delete f))
        (.delete tarball)))

    ;; Create native/ directory
    (if (.exists native-dir)
      (println "  native/ already exists, preserving user files")
      (.mkdirs native-dir))

    ;; Copy host source into native/
    (let [host-src (io/file ".redin/src/host")]
      (when (.exists host-src)
        (println "  Copying host source into native/...")
        (doseq [f (file-seq host-src)]
          (let [rel (.relativize (.toPath host-src) (.toPath f))
                target (io/file native-dir (.toString rel))]
            (if (.isDirectory f)
              (.mkdirs target)
              ;; Don't overwrite user-created files not in framework
              (when (or (not (.exists target))
                        ;; Always update framework files
                        (not= (.getName target) "providers.odin"))
                (.mkdirs (.getParentFile target))
                (io/copy f target)))))))

    ;; Write providers.odin if it doesn't exist
    (let [providers-file (io/file native-dir "providers.odin")]
      (when-not (.exists providers-file)
        (spit providers-file providers-odin)))

    ;; Inject init_providers() into main.odin if not already present
    (let [main-file (io/file native-dir "main.odin")
          content (slurp main-file)]
      (when-not (str/includes? content "init_providers")
        (spit main-file
              (str/replace content
                           "bridge.load_app(&b, app_file)"
                           "bridge.load_app(&b, app_file)\n\n\t// Register custom canvas providers\n\tinit_providers()"))))

    ;; Write build.sh
    (let [bs (io/file native-dir "build.sh")]
      (spit bs build-sh)
      (.setExecutable bs true))

    ;; Update redinw to prefer native build
    (spit "redinw" redinw-native-script)
    (.setExecutable (io/file "redinw") true)

    ;; Update .gitignore
    (let [gi (slurp ".gitignore")]
      (when-not (str/includes? gi "build/")
        (spit ".gitignore" (str gi "build/\n"))))

    (println)
    (println "Done! Native development ready.")
    (println "  cd native && ./build.sh    # build custom binary")
    (println "  ./redinw --dev main.fnl    # runs native build if available")
    (println)))

(defn cmd-update [version-arg]
  (when-not (.exists (io/file ".redin"))
    (println "Not a redin project (no .redin/ directory).")
    (println "Run this from your project root.")
    (System/exit 1))

  (let [current (str/trim (slurp ".redin/version"))
        version (or version-arg (fetch-latest-version))]
    (if (= current version)
      (println (str "Already on " version))
      (do
        (println (str "Updating from " current " to " version))
        (install-release "." version)
        (println "Done!")))))

(defn cmd-latest []
  (let [version (fetch-latest-version)]
    (println version)))

